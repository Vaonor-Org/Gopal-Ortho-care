// ============================================================
//  Gopal Ortho Care — Firestore Security Rules
//  Update these at:
//  https://console.firebase.google.com/project/gopal-fd3d8/firestore/rules
// ============================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Patients collection — only authenticated users (admins) can read/write
    match /patients/{patientId} {
      allow read, write: if request.auth != null;
    }

    // Block all other documents
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
