rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the caller an authorised admin?
    function isAdmin() {
      return request.auth != null &&
             request.auth.token.email in [
               'gopalorthocare@gmail.com',
               'whitedevil874@gmail.com'
             ];
    }

    // Admins collection — only admins can read; write only for own doc
    match /admins/{email} {
      allow read:  if isAdmin();
      allow write: if isAdmin() && request.auth.token.email == email;
    }

    // Patients — admin only
    match /patients/{id} {
      allow read, write: if isAdmin();
    }

    // Rooms — admin only
    match /rooms/{id} {
      allow read, write: if isAdmin();
    }

    // Room Logs — admin only
    match /roomLogs/{id} {
      allow read, write: if isAdmin();
    }

    // Bills — admin only
    match /bills/{id} {
      allow read, write: if isAdmin();
    }

    // Notice Board Tasks — admin only
    match /noticeTasks/{id} {
      allow read, write: if isAdmin();
    }

    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
