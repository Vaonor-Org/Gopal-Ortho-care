rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Patients — authenticated admin only
    match /patients/{id} {
      allow read, write: if request.auth != null;
    }

    // Rooms — authenticated admin only
    match /rooms/{id} {
      allow read, write: if request.auth != null;
    }

    // Room Logs — history of check-ins/outs
    match /roomLogs/{id} {
      allow read, write: if request.auth != null;
    }

    // Bills — authenticated admin only
    match /bills/{id} {
      allow read, write: if request.auth != null;
    }

    // Notice Board Tasks
    match /noticeTasks/{id} {
      allow read, write: if request.auth != null;
    }

    // Block all else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
